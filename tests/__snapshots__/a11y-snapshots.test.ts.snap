exports[`Accessibility tree snapshots form with all input types 1`] = `
"[page]
  [form] Registration
    Name
    [textbox] Name (required, placeholder: "Your name")
    Email
    [textbox] Email (required)
    [checkbox] I agree (unchecked)
    I agree
    [combobox] Role (value: "admin")
      [option]
        User
      [option] (selected)
        Admin
    [button] Register
      Register"
`;

